# ===========================================
# Homelab Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ALL configurable values go here.
# ===========================================

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN_BASE=homelab.<user>.dev

# ===========================================
# Traefik Reverse Proxy
# ===========================================
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# Cloudflare API credentials for DNS-01 challenge
CLOUDFLARE_EMAIL=your-cloudflare-email@example.com
CLOUDFLARE_DNS_API_TOKEN=your-cloudflare-dns-api-token

# Traefik dashboard basic auth (bcrypt or apr1 hash)
# Generate with: docker run --rm httpd:2-alpine htpasswd -nb admin yourpassword
# Note: Double any $ signs ($ -> $$) in the hash
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$REPLACE_WITH_GENERATED_HASH
# Alternative bcrypt: echo 'admin:yourpassword' | docker run --rm -i xmartlabs/htpasswd admin
# Then double the $ signs

# ===========================================
# PIA VPN (Gluetun)
# ===========================================
PIA_USERNAME=your-pia-username
PIA_PASSWORD=your-pia-password
PIA_REGION=Netherlands

# ===========================================
# Media Services
# ===========================================
PUID=1000
PGID=1000
TZ=Etc/UTC

# ===========================================
# Homarr Dashboard
# ===========================================
# Generate with: openssl rand -hex 32
HOMARR_SECRET_ENCRYPTION_KEY=replace-with-generated-key

# ===========================================
# Uptime Kuma
# ===========================================
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=replace-with-generated-password
UPTIME_KUMA_API_KEY=replace-with-generated-api-key

# ===========================================
# Beszel Monitoring
# ===========================================
# Universal token for agent self-registration (created via hub API)
BESZEL_AGENT_TOKEN=replace-with-token-from-hub
# SSH public key from hub (extracted from data/beszel/id_ed25519)
BESZEL_AGENT_KEY=ssh-ed25519 replace-with-key-from-hub

# ===========================================
# Immich
# ===========================================
IMMICH_VERSION=v3.0.3
DB_PASSWORD=replace-with-random-password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
UPLOAD_LOCATION=../../data/immich/library
DB_DATA_LOCATION=../../data/immich/postgres
DB_HOSTNAME=homelab-immich-postgres
REDIS_HOSTNAME=homelab-immich-redis
MACHINE_LEARNING_HOSTNAME=homelab-immich-ml
