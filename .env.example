# ===========================================
# Homelab Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN_BASE=homelab.pratcode.dev

# ===========================================
# Traefik / Reverse Proxy
# ===========================================
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# Cloudflare credentials for DNS challenge
# Create an API token with Zone:DNS:Edit permissions
CLOUDFLARE_EMAIL=your-cloudflare-email@example.com
CLOUDFLARE_DNS_API_TOKEN=your-cloudflare-dns-api-token

# Traefik dashboard basic auth
# Generate with: docker run --rm httpd:2-alpine htpasswd -nb admin yourpassword
# Note: Double all $ signs ($ -> $$) before pasting here
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$REPLACE_WITH_GENERATED_HASH

# ===========================================
# Grafana
# ===========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ===========================================
# Prometheus (basic auth if needed)
# ===========================================
# PROMETHEUS_BASIC_AUTH_USER=admin
# PROMETHEUS_BASIC_AUTH_PASSWORD=changeme_prometheus_password

# ===========================================
# Node Exporter target (Mac Mini IP/hostname)
# ===========================================
NODE_EXPORTER_HOST=localhost
NODE_EXPORTER_PORT=9100
